{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NotFair OpenClaw Audit",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "warning",
              "info"
            ]
          },
          "confidence": {
            "type": "number"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_action_type": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "title",
          "severity",
          "evidence"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "site_id",
    "generated_at",
    "summary",
    "issues"
  ],
  "additionalProperties": true
}
