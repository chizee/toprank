{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NotFair OpenClaw Portfolio",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "portfolio_id": {
      "type": "string"
    },
    "sites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "site_id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "business_weight": {
            "type": "number"
          },
          "cadence": {
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "monthly",
              "on_demand"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "paused",
              "archived"
            ]
          }
        },
        "required": [
          "site_id",
          "business_weight",
          "cadence",
          "status"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "schema_version",
    "portfolio_id",
    "sites"
  ],
  "additionalProperties": true
}
