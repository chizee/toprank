  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "trigger": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recent_actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
