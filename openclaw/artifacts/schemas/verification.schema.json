{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NotFair OpenClaw Verification",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warning",
              "fail",
              "not_run"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "name",
          "status"
        ],
        "additionalProperties": true
      }
    },
    "follow_up_due": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "site_id",
    "generated_at",
    "checks"
  ],
  "additionalProperties": true
}
