{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NotFair OpenClaw Action Plan",
  "type": "object",
  "properties": {
    "site_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "goal_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "priority_score": {
            "type": "number"
          },
          "expected_impact": {
            "type": "string"
          },
          "requires_approval": {
            "type": "boolean"
          },
          "reversibility": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "owner": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "action_id",
          "title",
          "type",
          "priority_score",
          "requires_approval"
        ],
        "additionalProperties": true
      }
    }
  },
  "required": [
    "site_id",
    "generated_at",
    "actions"
  ],
  "additionalProperties": true
}
