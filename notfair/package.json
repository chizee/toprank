{
  "name": "notfair",
  "version": "0.9.18",
  "description": "Goal-driven, loop-powered marketing agents that crush your business goals 24/7 — on your own machine. Say 'cut CAC to $30' and a dedicated agent turns it into a server-verified metric, then moves the number check after check while you sleep. Rides your existing Claude Code or Codex login.",
  "license": "MIT",
  "bin": {
    "notfair": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 3326",
    "build": "next build && node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "cli": "node bin/cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@next/env": "16.2.6",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@swc/helpers": "^0.5.21",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "commander": "^12.1.0",
    "cron-parser": "^5.5.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "open": "^10.1.0",
    "playwright-core": "^1.60.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "ws": "^8.20.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "keytar",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "node-pty"
    ]
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ]
}
